def add(a, b):

    return a + b

sum = add(5, 5)

print(sum)

Output:

10

## Problem 2 – Cube Function

def cube(n):

    return n ** 3

x = cube(2)

print(x)

Output:

8

## Problem 3 – Largest Number

def largest(a, b):

    if a > b:
        return a

    else:
        return b

x = largest(20, 10)

print(x)

Output:

20

## Problem 4 – Positive / Negative / Zero Check
def check(n):

    if n > 0:
        return "Positive"

    elif n < 0:
        return "Negative"

    elif n == 0:
        return "Zero"

x = check(-5)

print(x)

Output:

Negative

## Problem 5 – Smallest Number
def smallest(a, b):

    if a < b:
        return a

